generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
  MEMBER
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String
  avatarUrl     String?
  role          Role      @default(MEMBER)
  familyId      String?
  family        Family?   @relation(fields: [familyId], references: [id])
  posts         Post[]
  expensesPaid  Expense[] @relation("expense_paid_by")
  expenses      Expense[] @relation("expense_created_by")
  notifications Notification[]
  sessions      Session[]
  accounts      Account[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Family {
  id           String       @id @default(cuid())
  name         String
  destinations String[]
  startDate    DateTime?
  endDate      DateTime?
  inviteCode   String       @unique
  managerId    String
  users        User[]
  flights      Flight[]
  hotels       Hotel[]
  attractions  Attraction[]
  expenses     Expense[]
  posts        Post[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("families")
}

model Flight {
  id            String   @id @default(cuid())
  familyId      String
  family        Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  airline       String
  flightNumber  String
  departure     String
  arrival       String
  departureTime DateTime
  arrivalTime   DateTime
  terminal      String?
  gate          String?
  status        String   @default("scheduled")
  createdBy     String
  createdAt     DateTime @default(now())

  @@map("flights")
}

model Hotel {
  id         String   @id @default(cuid())
  familyId   String
  family     Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  name       String
  address    String?
  checkIn    DateTime
  checkOut   DateTime
  bookingRef String?
  price      Float?
  currency   String   @default("USD")
  status     String   @default("confirmed")
  createdBy  String
  createdAt  DateTime @default(now())

  @@map("hotels")
}

model Attraction {
  id          String   @id @default(cuid())
  familyId    String
  family      Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  name        String
  type        String
  location    String?
  visitDate   DateTime?
  ticketPrice Float?
  bookingRef  String?
  notes       String?
  createdBy   String
  createdAt   DateTime @default(now())

  @@map("attractions")
}

model Expense {
  id          String   @id @default(cuid())
  familyId    String
  family      Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  category    String
  amount      Float
  currency    String   @default("USD")
  description String?
  receiptUrl  String?
  paidBy      String
  paidByUser  User?    @relation("expense_paid_by", fields: [paidBy], references: [id])
  createdBy   String
  createdByUser User?  @relation("expense_created_by", fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())

  @@map("expenses")
}

model Post {
  id           String     @id @default(cuid())
  familyId     String
  family       Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String
  title        String?
  url          String?
  thumbnailUrl String?
  content      String?
  platform     String?
  reactions    Json       @default("{}")
  comments     Comment[]
  createdAt    DateTime   @default(now())

  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  createdAt DateTime @default(now())

  @@map("comments")
}

model Suggestion {
  id          String   @id @default(cuid())
  destination String
  title       String
  description String
  category    String
  imageUrl    String?
  sourceUrl   String?
  lat         Float?
  lng         Float?
  rating      Float?
  tags        String[]
  createdAt   DateTime @default(now())

  @@map("suggestions")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId  String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}
